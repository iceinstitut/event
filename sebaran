    <style>
        /* Penyesuaian kontrol peta agar sesuai dengan tampilan premium */
        .leaflet-bar {
            border: none !important;
            box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1) !important;
        }
        .leaflet-bar a {
            background-color: #ffffff !important;
            color: #1f2937 !important;
            border-bottom: 1px solid #e5e7eb !important;
            transition: all 0.2s;
        }
        .leaflet-bar a:hover {
            background-color: #f3f4f6 !important;
            color: #4f46e5 !important;
        }
        .dark-theme .leaflet-bar a {
            background-color: #1f2937 !important;
            color: #f9fafb !important;
            border-bottom: 1px solid #374151 !important;
        }
        .dark-theme .leaflet-bar a:hover {
            background-color: #374151 !important;
            color: #818cf8 !important;
        }
        /* Animasi cincin berdenyut kustom */
        @keyframes pulse-ring {
            0% { transform: scale(0.33); opacity: 0; }
            50% { opacity: 0.6; }
            100% { transform: scale(1); opacity: 0; }
        }
        .pulse-marker-ring {
            animation: pulse-ring 2s cubic-bezier(0.215, 0.610, 0.355, 1) infinite;
        }
        /* Penataan bilah gulir (scrollbar) */
        ::-webkit-scrollbar {
            width: 6px;
        }
        ::-webkit-scrollbar-track {
            background: transparent;
        }
        ::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 4px;
        }
        .dark-theme ::-webkit-scrollbar-thumb {
            background: #4b5563;
        }
    </style>
</head>
<body class="bg-slate-50 text-slate-800 font-sans transition-colors duration-300 h-screen flex flex-col overflow-hidden">

    <!-- Bagian Header -->
    <header class="bg-white dark:bg-slate-900 border-b border-slate-200 dark:border-slate-800 px-6 py-4 flex flex-col sm:flex-row justify-between items-center shrink-0 gap-4 transition-colors duration-300">
        <div class="flex items-center gap-3">
            <div class="p-2.5 bg-indigo-600 text-white rounded-xl shadow-lg shadow-indigo-500/20">
                <i data-lucide="globe" class="w-6 h-6"></i>
            </div>
            <div>
                <h1 class="text-xl font-bold text-slate-900 dark:text-white leading-tight">Peta Peserta Global</h1>
                <p class="text-xs text-slate-500 dark:text-slate-400">Visualisasi geografis & wawasan interaktif</p>
            </div>
        </div>
        
        <!-- Kontrol Header -->
        <div class="flex items-center gap-3 w-full sm:w-auto justify-end">
            <!-- Pengubah Tema -->
            <button id="themeToggleBtn" class="p-2.5 rounded-xl border border-slate-200 dark:border-slate-800 text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors" title="Ubah Tema">
                <i id="themeIcon" data-lucide="moon" class="w-5 h-5"></i>
            </button>
            <!-- Atur Ulang Peta -->
            <button id="resetMapBtn" class="flex items-center gap-2 px-4 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white font-medium text-sm rounded-xl shadow-md shadow-indigo-500/10 transition-all">
                <i data-lucide="map-pin" class="w-4 h-4"></i>
                Atur Ulang
            </button>
        </div>
    </header>

    <!-- Kontainer Utama Dasbor -->
    <main class="flex-1 flex flex-col md:flex-row overflow-hidden relative">
        
        <!-- Sidebar Kiri -->
        <section id="sidebar" class="w-full md:w-96 bg-white dark:bg-slate-900 border-r border-slate-200 dark:border-slate-800 flex flex-col overflow-hidden transition-all duration-300 z-[10] shrink-0">
            
            <!-- Panel Statistik Ringkas -->
            <div class="p-5 border-b border-slate-100 dark:border-slate-800 bg-slate-50/50 dark:bg-slate-900/50 grid grid-cols-2 gap-3 shrink-0">
                <div class="bg-white dark:bg-slate-800 p-3 rounded-xl border border-slate-200/60 dark:border-slate-700/50 shadow-sm">
                    <span class="text-xs font-semibold text-slate-400 dark:text-slate-500 uppercase tracking-wider block">Total Peserta</span>
                    <span id="statTotal" class="text-2xl font-bold text-slate-900 dark:text-white mt-1 block">-</span>
                </div>
                <div class="bg-white dark:bg-slate-800 p-3 rounded-xl border border-slate-200/60 dark:border-slate-700/50 shadow-sm">
                    <span class="text-xs font-semibold text-slate-400 dark:text-slate-500 uppercase tracking-wider block">Kota Aktif</span>
                    <span id="statCities" class="text-2xl font-bold text-slate-900 dark:text-white mt-1 block">-</span>
                </div>
                <div class="bg-white dark:bg-slate-800 p-3 rounded-xl border border-slate-200/60 dark:border-slate-700/50 shadow-sm col-span-2 flex items-center justify-between">
                    <div>
                        <span class="text-xs font-semibold text-slate-400 dark:text-slate-500 uppercase tracking-wider block">Lokasi Terbanyak</span>
                        <span id="statTopCity" class="text-sm font-bold text-slate-900 dark:text-white truncate max-w-[180px] mt-0.5 block">-</span>
                    </div>
                    <div class="h-9 w-9 rounded-lg bg-emerald-500/10 text-emerald-600 dark:text-emerald-400 flex items-center justify-center">
                        <i data-lucide="trending-up" class="w-5 h-5"></i>
                    </div>
                </div>
            </div>

            <!-- Kontainer Filter -->
            <div class="p-5 border-b border-slate-200 dark:border-slate-800 space-y-4 shrink-0">
                <!-- Kotak Pencarian -->
                <div class="relative">
                    <span class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none text-slate-400 dark:text-slate-500">
                        <i data-lucide="search" class="w-4 h-4"></i>
                    </span>
                    <input type="text" id="searchInput" placeholder="Cari kota atau negara..." class="w-full pl-9 pr-4 py-2.5 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 text-sm text-slate-900 dark:text-white placeholder-slate-400 dark:placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-all">
                </div>

                <!-- Filter Batas Volume Peserta -->
                <div>
                    <div class="flex justify-between items-center mb-1.5">
                        <label for="volumeFilter" class="text-xs font-semibold text-slate-500 dark:text-slate-400">Min. Peserta</label>
                        <span id="volumeValue" class="text-xs font-bold text-indigo-600 dark:text-indigo-400 bg-indigo-50 dark:bg-indigo-950/50 px-2 py-0.5 rounded-full">0</span>
                    </div>
                    <input type="range" id="volumeFilter" min="0" max="10000" step="100" value="0" class="w-full h-1.5 bg-slate-200 dark:bg-slate-700 rounded-lg appearance-none cursor-pointer accent-indigo-600">
                </div>
            </div>

            <!-- Header Daftar Lokasi -->
            <div class="px-5 py-3 border-b border-slate-100 dark:border-slate-800 bg-slate-50/30 dark:bg-slate-900/30 flex justify-between items-center shrink-0">
                <span class="text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Daftar Lokasi</span>
                <span id="filteredCount" class="text-xs text-slate-400 font-medium">Menampilkan semua</span>
            </div>

            <!-- Daftar Lokasi Gulir -->
            <div id="locationList" class="flex-1 overflow-y-auto divide-y divide-slate-100 dark:divide-slate-800/60">
                <!-- Elemen lokasi akan disisipkan secara dinamis di sini -->
            </div>
        </section>

        <!-- Kontainer Peta -->
        <section class="flex-1 h-full relative">
            <div id="map" class="w-full h-full z-[1]"></div>
            
            <!-- Legenda Peta -->
            <div class="absolute bottom-6 right-6 z-[400] bg-white/95 dark:bg-slate-900/95 backdrop-blur-md px-4 py-3 rounded-2xl shadow-xl border border-slate-200/80 dark:border-slate-800/80 max-w-xs transition-colors duration-300">
