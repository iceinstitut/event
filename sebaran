{ id: 673, city: "Kabupaten Kepulauan Mentawai", country: "Indonesia", lat:-1.426001, lng: 98.9245343, count: 1 },
{ id: 674, city: "Fengxian", country: "China", lat:34.6939, lng: 116.5953, count: 1 },
{ id: 675, city: "Guang'an", country: "China", lat:30.456, lng: 106.6332, count: 1 },
{ id: 676, city: "Hambantota", country: "Sri Lanka", lat:6.1412361, lng: 81.0958489, count: 1 }
        ];

        // Pengaturan & Konstanta Global
        let isDarkTheme = false;
        let map;
        let tileLayer;
        let markersGroup;
        const markerRefs = {}; // Menyimpan referensi penanda berdasarkan ID

        // Sumber Tile Peta (Light/Dark)
        const lightTiles = 'https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png';
        const darkTiles = 'https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png';
        const attribution = '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors &copy; <a href="https://carto.com/attributions">CARTO</a>';

        // Konfigurasi posisi awal peta
        const initialLatLng = [20, 10];
        const initialZoom = 2.4;

        // Inisialisasi Aplikasi ketika DOM siap
        window.addEventListener('DOMContentLoaded', () => {
            lucide.createIcons();
            initTheme();
            initMap();
            updateStats(participantData);
            renderLocationsList(participantData);
            plotMarkers(participantData);
            showWelcomeAlert();

            // Perekam aksi interaktif
            document.getElementById('themeToggleBtn').addEventListener('click', toggleTheme);
            document.getElementById('resetMapBtn').addEventListener('click', resetMapView);
            document.getElementById('searchInput').addEventListener('input', handleFilters);
            document.getElementById('volumeFilter').addEventListener('input', (e) => {
                document.getElementById('volumeValue').textContent = parseInt(e.target.value).toLocaleString();
                handleFilters();
            });
        });

        // Inisialisasi Peta Leaflet
        function initMap() {
            map = L.map('map', {
                center: initialLatLng,
                zoom: initialZoom,
                minZoom: 2,
                maxZoom: 14,
                zoomControl: true,
                attributionControl: true
            });

            tileLayer = L.tileLayer(isDarkTheme ? darkTiles : lightTiles, {
                attribution: attribution
            }).addTo(map);

            markersGroup = L.layerGroup().addTo(map);
        }

        // Hitung ukuran lingkaran secara dinamis berdasarkan rentang jumlah peserta (1 - 10000)
        // Menggunakan skala logaritmik agar visualisasi ukuran lingkaran seimbang dan estetis
        function getMarkerSize(count) {
            const minCount = 1;
            const maxCount = 10000;
            const minSize = 14;  // Diameter minimum (dalam piksel)
            const maxSize = 60;  // Diameter maksimum (dalam piksel)

            // Batasi nilai count di dalam rentang
            const clamped = Math.max(minCount, Math.min(maxCount, count));
            
            const logMin = Math.log(minCount);
            const logMax = Math.log(maxCount);
            const logVal = Math.log(clamped);

            // Hitung nilai skala linear antara 0 dan 1
            const scale = (logVal - logMin) / (logMax - logMin);
            
            // Hitung diameter akhir dalam piksel
            return Math.round(minSize + scale * (maxSize - minSize));
        }

        // Dapatkan kelas warna berdasarkan jumlah peserta
        function getDensityStyles(count) {
            if (count >= 1000) {
                return {
                    color: '#10b981', // emerald-500
                    bg: 'bg-emerald-500',
                    badge: 'bg-emerald-50 text-emerald-700 dark:bg-emerald-950/40 dark:text-emerald-400'
                };
            } else if (count >= 500) {
                return {
                    color: '#6366f1', // indigo-500
                    bg: 'bg-indigo-500',
                    badge: 'bg-indigo-50 text-indigo-700 dark:bg-indigo-950/40 dark:text-indigo-400'
                };
            } else {
                return {
                    color: '#f59e0b', // amber-500
                    bg: 'bg-rose-500',
                    badge: 'bg-rose-50 text-amber-700 dark:bg-rose-950/40 dark:text-amber-400'
                };
            }
        }

        // Plot penanda pada peta secara dinamis
        function plotMarkers(dataList) {
            markersGroup.clearLayers(); // Bersihkan penanda lama

            dataList.forEach(item => {
                const style = getDensityStyles(item.count);
                const size = getMarkerSize(item.count); // Ukuran dinamis

                // Buat ikon DOM kustom menggunakan Leaflet divIcon
                // className kosong/tanpa relative agar tidak memecah layout posisi absolut Leaflet.
                // Menggunakan iconAnchor: [size/2, size/2] agar titik koordinat terkunci di tengah lingkaran secara presisi.
                const customIcon = L.divIcon({
                    className: 'bg-transparent border-none', 
                    html: `
                        <div class="w-full h-full flex items-center justify-center">
                            <!-- Lingkaran berdenyut di latar belakang -->
                            <div class="absolute w-full h-full rounded-full ${style.bg} pulse-marker-ring opacity-50"></div>
                            <!-- Lingkaran inti penanda -->
                            <div class="relative rounded-full ${style.bg} border border-white dark:border-slate-900 shadow-md transition-transform hover:scale-125 duration-150" style="width: ${Math.max(8, size * 0.7)}px; height: ${Math.max(8, size * 0.7)}px;"></div>
                        </div>
                    `,
                    iconSize: [size, size],
                    iconAnchor: [size / 2, size / 2]
                });

                // Buat penanda koordinat
                const marker = L.marker([item.lat, item.lng], { icon: customIcon }).addTo(markersGroup);
                
                // Simpan referensi penanda
                markerRefs[item.id] = marker;

                // Atur popup informasi
                const popupContent = `
                    <div class="p-3 font-sans w-52 bg-white dark:bg-slate-900 text-slate-800 dark:text-white rounded-lg transition-all">
                        <div class="flex items-center gap-1.5 text-[10px] uppercase font-semibold text-slate-400">
                            <i class="w-3.5 h-3.5 inline-block" data-lucide="map-pin"></i>
                            ${item.country}
                        </div>
                        <h3 class="text-base font-bold text-slate-900 dark:text-white mt-1 leading-tight">${item.city}</h3>
                        <div class="mt-3 flex items-center justify-between border-t border-slate-100 dark:border-slate-800 pt-2.5">
                            <span class="text-xs font-medium text-slate-500 dark:text-slate-400">Peserta</span>
                            <span class="px-2.5 py-1 text-xs font-bold rounded-lg ${style.badge}">
                                ${item.count.toLocaleString('id-ID')}
                            </span>
                        </div>
                    </div>
                `;

                marker.bindPopup(popupContent, {
                    closeButton: false,
                    className: 'custom-leaflet-popup shadow-2xl rounded-2xl border-none'
                });

                // Peristiwa klik penanda
                marker.on('click', () => {
                    map.setView([item.lat, item.lng], 6, {
                        animate: true,
                        duration: 0.8
                    });
                    highlightSidebarItem(item.id);
                });
            });
        }

        // Render Panel Daftar Samping
        function renderLocationsList(dataList) {
            const listContainer = document.getElementById('locationList');
            listContainer.innerHTML = '';

            if (dataList.length === 0) {
                listContainer.innerHTML = `
                    <div class="p-8 text-center text-slate-400 dark:text-slate-500 flex flex-col items-center justify-center">
                        <i data-lucide="map" class="w-8 h-8 mb-2 opacity-50"></i>
                        <p class="text-sm font-medium">Hasil tidak ditemukan</p>
                        <p class="text-xs opacity-75 mt-0.5">Coba ubah pengaturan filter Anda</p>
                    </div>
                `;
                lucide.createIcons();
                return;
            }

            dataList.forEach(item => {
                const style = getDensityStyles(item.count);
                
                const itemDiv = document.createElement('div');
                itemDiv.id = `list-item-${item.id}`;
                itemDiv.className = `p-4 cursor-pointer hover:bg-slate-50 dark:hover:bg-slate-800/50 transition-colors flex justify-between items-center border-l-4 border-transparent`;
                itemDiv.innerHTML = `
                    <div class="min-w-0 pr-3">
                        <div class="flex items-center gap-1.5">
                            <h4 class="font-bold text-sm text-slate-800 dark:text-slate-200 truncate">${item.city}</h4>
                        </div>
                        <p class="text-xs text-slate-400 dark:text-slate-500 mt-0.5 flex items-center gap-1">
                            <span class="inline-block w-2 h-2 rounded-full ${style.bg}"></span>
                            ${item.country}
                        </p>
                    </div>
                    <div class="text-right shrink-0">
                        <span class="inline-block px-2.5 py-1 text-xs font-bold rounded-lg ${style.badge}">
                            ${item.count.toLocaleString('id-ID')}
                        </span>
                    </div>
                `;

                // Aksi saat item daftar diklik
                itemDiv.addEventListener('click', () => {
                    focusOnLocation(item);
                });

                listContainer.appendChild(itemDiv);
            });

            lucide.createIcons();
        }

        // Fokuskan peta dan buka balon informasi popup
        function focusOnLocation(item) {
            document.querySelectorAll('[id^="list-item-"]').forEach(el => {
                el.classList.remove('border-indigo-600', 'bg-indigo-50/50', 'dark:bg-indigo-950/20');
            });

            const listItem = document.getElementById(`list-item-${item.id}`);
            if (listItem) {
                listItem.classList.add('border-indigo-600', 'bg-indigo-50/50', 'dark:bg-indigo-950/20');
                listItem.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
            }

            map.setView([item.lat, item.lng], 6, {
                animate: true,
                duration: 1
            });

            const marker = markerRefs[item.id];
            if (marker) {
                setTimeout(() => {
                    marker.openPopup();
                }, 500);
            }
        }

        // Berikan penanda aktif pada item daftar ketika penanda peta diklik
        function highlightSidebarItem(id) {
            document.querySelectorAll('[id^="list-item-"]').forEach(el => {
                el.classList.remove('border-indigo-600', 'bg-indigo-50/50', 'dark:bg-indigo-950/20');
            });

            const listItem = document.getElementById(`list-item-${id}`);
            if (listItem) {
                listItem.classList.add('border-indigo-600', 'bg-indigo-50/50', 'dark:bg-indigo-950/20');
                listItem.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
            }
        }

        // Pengolah filter pencarian dan volume
        function handleFilters() {
            const searchQuery = document.getElementById('searchInput').value.toLowerCase().trim();
            const minVolume = parseInt(document.getElementById('volumeFilter').value);

            const filteredData = participantData.filter(item => {
                const matchesSearch = item.city.toLowerCase().includes(searchQuery) || 
                                      item.country.toLowerCase().includes(searchQuery);
                const matchesVolume = item.count >= minVolume;
                return matchesSearch && matchesVolume;
            });

            updateStats(filteredData);
            renderLocationsList(filteredData);
            plotMarkers(filteredData);

            const countText = document.getElementById('filteredCount');
            if (filteredData.length === participantData.length) {
                countText.textContent = "Menampilkan semua";
            } else {
                countText.textContent = `Menampilkan ${filteredData.length} dari ${participantData.length}`;
            }
        }

        // Perbarui panel statistik ringkas secara dinamis
        function updateStats(dataList) {
            if (dataList.length === 0) {
                document.getElementById('statTotal').textContent = "0";
                document.getElementById('statCities').textContent = "0";
                document.getElementById('statTopCity').textContent = "-";
                return;
            }

            const total = dataList.reduce((sum, current) => sum + current.count, 0);
            document.getElementById('statTotal').textContent = total.toLocaleString('id-ID');

            document.getElementById('statCities').textContent = dataList.length;

            const topCityItem = dataList.reduce((prev, current) => (prev.count > current.count) ? prev : current);
            document.getElementById('statTopCity').textContent = `${topCityItem.city}, ${topCityItem.country.substring(0, 2).toUpperCase()}`;
            document.getElementById('statTopCity').title = `${topCityItem.city}, ${topCityItem.country}`;
        }

        // Atur ulang sudut pandang peta ke awal
        function resetMapView() {
            map.setView(initialLatLng, initialZoom, {
                animate: true,
                duration: 1
            });
            document.querySelectorAll('[id^="list-item-"]').forEach(el => {
                el.classList.remove('border-indigo-600', 'bg-indigo-50/50', 'dark:bg-indigo-950/20');
            });
            map.closePopup();
        }

        // Inisialisasi preferensi tema gelap/terang
        function initTheme() {
            if (localStorage.getItem('theme') === 'dark' || 
                (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
                enableDarkTheme();
            } else {
                disableDarkTheme();
            }
        }

        // Ganti tema visual sistem
        function toggleTheme() {
            if (isDarkTheme) {
                disableDarkTheme();
            } else {
                enableDarkTheme();
            }
            if (tileLayer && map) {
                tileLayer.setUrl(isDarkTheme ? darkTiles : lightTiles);
            }
        }

        function enableDarkTheme() {
            document.documentElement.classList.add('dark');
            document.body.classList.add('dark-theme');
            isDarkTheme = true;
            localStorage.setItem('theme', 'dark');
            document.getElementById('themeIcon').setAttribute('data-lucide', 'sun');
            lucide.createIcons();
        }

        function disableDarkTheme() {
            document.documentElement.classList.remove('dark');
            document.body.classList.remove('dark-theme');
            isDarkTheme = false;
            localStorage.setItem('theme', 'light');
            document.getElementById('themeIcon').setAttribute('data-lucide', 'moon');
            lucide.createIcons();
        }

        // Tampilkan pemberitahuan selamat datang
        function showWelcomeAlert() {
            const alertBox = document.getElementById('welcomeAlert');
            alertBox.classList.remove('hidden');
            setTimeout(() => {
                closeWelcome();
            }, 6000);
        }

        function closeWelcome() {
            const alertBox = document.getElementById('welcomeAlert');
            alertBox.classList.add('hidden');
        }
    </script>
